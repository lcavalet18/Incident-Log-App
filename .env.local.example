# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key is only used by the local seed script (scripts/seed.ts).
# NEVER expose this in client code or commit it. Not needed for the app to run.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
